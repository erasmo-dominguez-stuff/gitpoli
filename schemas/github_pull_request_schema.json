{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "github_pull_request_policy",
  "description": "Schema for the pull request policy configuration (.repol/pullrequest.yaml)",
  "type": "object",
  "required": ["policy"],
  "additionalProperties": false,
  "properties": {
    "policy": {
      "type": "object",
      "required": ["version", "rules"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string" },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "branch_rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "target"],
            "additionalProperties": false,
            "properties": {
              "source": { "type": "string", "minLength": 1 },
              "target": { "type": "string", "minLength": 1 }
            }
          }
        },
        "rules": {
          "type": "object",
          "required": ["approvals_required"],
          "additionalProperties": false,
          "properties": {
            "allowed_target_branches": {
              "anyOf": [
                { "type": "null" },
                {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 1
                }
              ]
            },
            "approvals_required": {
              "type": "integer",
              "minimum": 0
            },
            "signed_off": { "type": "boolean" }
          }
        }
      }
    }
  }
}
